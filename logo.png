<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="100%" height="100%">
  <defs>
    <!-- इमेज के अनुसार सटीक 4-कलर नियॉन ग्रेडिएंट -->
    <linearGradient id="factZoneGrad" x1="10%" y1="0%" x2="90%" y2="100%">
      <stop offset="0%" stop-color="#FFE169" />   <!-- Yellow / Top Left -->
      <stop offset="35%" stop-color="#FF5E97" />  <!-- Pink / Middle -->
      <stop offset="70%" stop-color="#A855F7" />  <!-- Purple / Lower Middle -->
      <stop offset="100%" stop-color="#6366F1" /> <!-- Blue-Purple / Bottom Right -->
    </linearGradient>
    
    <!-- इमेज जैसा असली नियॉन ग्लो इफ़ेक्ट -->
    <filter id="neonGlow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="7" result="blur1" />
      <feGaussianBlur stdDeviation="15" result="blur2" />
      <feMerge>
        <feMergeNode in="blur2" />
        <feMergeNode in="blur1" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <!-- इमेज का गहरा नेवी-ब्लैक बैकग्राउंड सर्कल -->
  <circle cx="256" cy="256" r="240" fill="#0A0F24" />

  <!-- ग्लोइंग कोर एलिमेंट्स -->
  <g filter="url(#neonGlow)">
    
    <!-- 1. आउटर ऑर्बिट्स (सटीक रोटेशन और शेप के साथ) -->
    <!-- वर्टिकल ओवल -->
    <ellipse cx="256" cy="245" rx="85" ry="155" fill="none" stroke="url(#factZoneGrad)" stroke-width="4.5" transform="rotate(-15 256 245)" />
    <!-- झुका हुआ ओवल 1 -->
    <ellipse cx="256" cy="245" rx="85" ry="155" fill="none" stroke="url(#factZoneGrad)" stroke-width="4.5" transform="rotate(45 256 245)" />
    <!-- झुका हुआ ओवल 2 -->
    <ellipse cx="256" cy="245" rx="85" ry="155" fill="none" stroke="url(#factZoneGrad)" stroke-width="4.5" transform="rotate(-65 256 245)" />

    <!-- 2. ऑर्बिट्स पर चमकते हुए सफ़ेद इलेक्ट्रॉन्स (ग्लो के साथ) -->
    <circle cx="218" cy="115" r="8" fill="#FFFFFF" />
    <circle cx="372" cy="115" r="8" fill="#FFFFFF" />
    <circle cx="140" cy="265" r="8" fill="#FFFFFF" />
    <circle cx="398" cy="252" r="8" fill="#FFFFFF" />

    <!-- 3. इमेज के जैसा शार्प ज्योमेट्रिक 'F' (इंटरलॉकिंग लाइन्स के साथ) -->
    <g stroke="url(#factZoneGrad)" stroke-width="5" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <!-- 'F' का मुख्य बाहरी स्ट्रक्चर -->
      <path d="M 215,310 L 215,160 L 315,160 L 290,195 L 215,195" />
      
      <!-- 'F' का बीच वाला विंग (Wing) -->
      <path d="M 215,225 L 280,225 L 260,255 L 215,255" />
      
      <!-- 'F' के अंदर के कट्स और एंगल्स (इमेज की तरह 3D वायरफ्रेम लुक के लिए) -->
      <path d="M 215,160 L 255,210 L 215,255" stroke-width="3" opacity="0.9" />
      <path d="M 315,160 L 245,195 L 215,195" stroke-width="3" opacity="0.9" />
      <path d="M 280,225 L 235,255" stroke-width="3" opacity="0.9" />
      <path d="M 215,195 L 215,225" />
      
      <!-- 'F' का निचला एजी कट -->
      <path d="M 215,310 L 235,280 L 215,255" />
    </g>

  </g>

  <!-- 4. "FACTZONE OFFICIAL" टेक्स्ट (इमेज के फॉन्ट और स्पेसिंग के अनुसार) -->
  <text x="256" y="420" 
        fill="#FFFFFF" 
        font-family="'Montserrat', 'Arial Black', sans-serif" 
        font-size="34" 
        font-weight="bold" 
        letter-spacing="4" 
        text-anchor="middle">FACTZONE</text>
        
  <text x="256" y="452" 
        fill="#FFFFFF" 
        font-family="'Montserrat', 'Arial', sans-serif" 
        font-size="18" 
        font-weight="600" 
        letter-spacing="8" 
        text-anchor="middle" 
        opacity="0.8">OFFICIAL</text>
</svg>
